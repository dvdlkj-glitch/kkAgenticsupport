# ============================================================
#  kkAgentic Support — environment configuration
#  Copy this file to ".env" and fill in your own values.
# ============================================================

# ---- OpenRouter (your 2 agents use 2 different models) ----
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Agent 1 = ROUTER (classifies which project a question belongs to).
# Agent 2 = ANSWER (RAG answer for the chosen project).
# Use whatever exact model slugs your OpenRouter account exposes.
# (Gemma family examples shown — replace with your "Gemma 4" slug if/when available.)
ROUTER_MODEL=google/gemma-3-12b-it
ANSWER_MODEL=google/gemma-3-27b-it

# Optional headers OpenRouter uses for attribution / rankings
OPENROUTER_SITE_URL=https://your-support-site.example
OPENROUTER_APP_NAME=kkAgentic Support

# ---- Supabase (Postgres + pgvector store) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE ROLE key for ingestion; anon key is fine for read-only chat.
SUPABASE_KEY=your-service-role-or-anon-key

# ---- Embeddings ----
# backend: "local" (sentence-transformers, free) or "openai" (OpenAI embeddings API)
EMBEDDING_BACKEND=local
EMBEDDING_MODEL_LOCAL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
# Only needed if EMBEDDING_BACKEND=openai
OPENAI_API_KEY=
EMBEDDING_MODEL_OPENAI=text-embedding-3-small

# ---- Retrieval ----
TOP_K=5
ROUTER_MIN_CONFIDENCE=0.45

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=123456:your-telegram-bot-token

# ---- Web page -> API ----
# Comma-separated list of origins allowed to call the FastAPI /chat endpoint.
CORS_ALLOW_ORIGINS=*

# ---- File uploads -> Google Drive ----
# The web chat lets users attach a screenshot or an issue .txt/.log file. The
# backend stores each file in a dedicated Google Drive folder (credentials stay
# server-side; the web page never sees them). If unset, files fall back to a
# local ./uploads folder so the feature still works in development.
#
# Setup:
#   1) In Google Cloud, create a Service Account and download its JSON key.
#   2) Enable the "Google Drive API" for that project.
#   3) Share the Drive folder below with the service account's client_email (Editor),
#      OR move the folder onto a Shared Drive the service account can access.
#   4) Point GOOGLE_SERVICE_ACCOUNT_FILE at the downloaded JSON key (local dev),
#      OR set GOOGLE_SERVICE_ACCOUNT_JSON to the key's raw JSON (Streamlit Cloud).
GOOGLE_SERVICE_ACCOUNT_FILE=
# Raw service-account JSON as a single string (used on Streamlit Cloud / when you
# can't ship a key file). Leave blank if you use GOOGLE_SERVICE_ACCOUNT_FILE.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Dedicated folder created for this app — uploads land here:
GDRIVE_UPLOAD_FOLDER_ID=1n85znNakl_5A_kkuC52faUbPQIUmL0Xj
# Local dev fallback directory (used only when the two values above are blank):
UPLOAD_LOCAL_DIR=uploads
UPLOAD_MAX_MB=10
UPLOAD_ALLOWED_EXT=.png,.jpg,.jpeg,.gif,.webp,.txt,.log
